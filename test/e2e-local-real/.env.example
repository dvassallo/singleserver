# Copy to .env and fill in real credentials. Do not commit .env.

# Cloudflare token scoped to the test zone and tunnel management.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
TEST_ZONE=singleserver.xyz

# Tailscale OAuth client for generating pre-authorized auth keys for E2E hosts.
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_TAG=tag:singleserver-e2e

# Optional fallback for joining the local test container to your tailnet.
TAILSCALE_AUTHKEY=

# Optional. Used for creating the OAuth client/tag and future cleanup helpers.
TAILSCALE_API_TOKEN=

# Dedicated GitHub App credentials. The app must be installed on GITHUB_TEST_REPO.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=

# Dedicated private repo used by the test. The runner creates it if missing.
GITHUB_TEST_REPO=dvassallo/singleserver-e2e-app

# Token used by gh/git to create and push commits to GITHUB_TEST_REPO.
# If omitted, the runner uses the currently authenticated gh account.
GITHUB_PUSH_TOKEN=
